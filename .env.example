# Copy to `.env.local` and fill in real values.
# Never commit this file with real secrets.

# ── Required — max-agent API connection ─────────────────────────────────────
DIGITALCREW_API_BASE_URL=https://max.yourdomain.com

# ── Upstream token (per-request preferred) ───────────────────────────────────
# Callers should send Authorization: Bearer on MCP requests, or bearer_token
# on tool args. Set ALLOW_ENV_TOKEN_FALLBACK=true only for legacy cron/scripts
# that cannot send a per-request token yet.
# DIGITALCREW_API_TOKEN=your-service-token-here
# ALLOW_ENV_TOKEN_FALLBACK=true

# ── Required in production — MCP gateway shared secret ──────────────────────
MCP_GATEWAY_SECRET=your-strong-random-gateway-secret-here

# ── Admin tools (separate key; checked at execution time) ─────────────────────
# MCP_ADMIN_GATEWAY_KEY=your-admin-only-gateway-key

# ── Hermes caller identity (Contract 3) ───────────────────────────────────────
# Shared HMAC secret used to verify the signed X-Hermes-Caller envelope that a
# company's Hermes agent sends (tenantId/agentId/capability/exp). MUST match the
# HERMES_CALLER_SECRET written into each Hermes container's .env. When unset, the
# feature is OFF: envelopes are ignored (not rejected) and no verified identity is
# forwarded downstream. When set, a PRESENT-but-invalid/expired envelope is a 401.
# HERMES_CALLER_SECRET=your-strong-random-hermes-caller-secret

# ── Optional — dangerous tools (off by default) ─────────────────────────────
# ENABLE_ADMIN_TOOLS=true
# ENABLE_WEBHOOK_SIMULATORS=true

# ── Optional — /chat rate limits ────────────────────────────────────────────
# CHAT_RATE_LIMIT_PER_MINUTE=20
# CHAT_DAILY_REQUEST_CAP=500

# ── Optional — Redis dead-letter queue ──────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ── Optional — chat relay (Mattermost integration) ────────────────────────────
# OPENROUTER_API_KEY=
