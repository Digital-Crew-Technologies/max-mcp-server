# Copy to `.env.local` and fill in real values.
# Never commit this file with real secrets.

# ─────────────────────────────────────────────────────────────────────────────
# Required — max-agent API connection
# DIGITALCREW_API_BASE_URL: full base URL of max-agent, e.g. https://max.yourdomain.com
# DIGITALCREW_API_TOKEN:    service token for max-agent internal API calls
# ─────────────────────────────────────────────────────────────────────────────
DIGITALCREW_API_BASE_URL=https://max.yourdomain.com
DIGITALCREW_API_TOKEN=your-service-token-here

# ─────────────────────────────────────────────────────────────────────────────
# Optional — fallback bearer token (used if DIGITALCREW_API_TOKEN is unset)
# ─────────────────────────────────────────────────────────────────────────────
# DIGITALCREW_BEARER_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Required in production — MCP gateway shared secret (see middleware.ts).
# Gates the /mcp endpoint: callers MUST send `X-MCP-Gateway-Key: <this value>`.
# This is a DIFFERENT secret from DIGITALCREW_API_TOKEN — do not reuse either.
# Generate one with:  openssl rand -base64 32
# If unset, /mcp returns 503 (the gate fails closed).
# ─────────────────────────────────────────────────────────────────────────────
MCP_GATEWAY_SECRET=your-strong-random-gateway-secret-here

# ─────────────────────────────────────────────────────────────────────────────
# Optional — Redis URL for the dead-letter queue of failed writes.
# Without this the dead-letter falls back to a bounded in-memory ring buffer
# (lost on restart). Inspect via the list_failed_requests MCP tool.
# ─────────────────────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# Optional — Observability. Structured JSON span logs are emitted to stdout
# by default (compatible with Vector, Fluent Bit, Datadog Agent, OTel
# Collector). Set OBSERVABILITY=off to silence them.
# ─────────────────────────────────────────────────────────────────────────────
# OBSERVABILITY=off
